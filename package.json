{
  "name": "pi-opencode-mode-extension",
  "version": "0.1.0",
  "description": "OpenCode-style build/plan mode switcher for Pi with read-only plan guards and RTK support.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "keywords": [
    "pi-coding-agent",
    "pi-extension",
    "opencode",
    "plan-mode",
    "rtk"
  ],
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node test/safety.test.mjs"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "@types/node": "latest",
    "typescript": "latest"
  }
}
